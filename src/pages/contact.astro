---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Troy Sybert at Voice of Repentance.">

  <section class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <h1 class="text-3xl md:text-4xl font-heading font-bold text-vor-charcoal mb-2">Get in Touch</h1>
    <p class="text-vor-charcoal-light mb-10">
      Whether you have a question about a post, want to share something, or just want to reach out — this goes directly to Troy.
    </p>

    <form id="contact-form" class="space-y-5">
      <div>
        <label for="name" class="block text-sm font-heading font-medium text-vor-charcoal mb-1">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full px-4 py-3 rounded-lg border border-vor-sand bg-white text-vor-charcoal font-body focus:outline-none focus:border-vor-gold-dark focus:ring-1 focus:ring-vor-gold-dark"
          placeholder="Your name"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-heading font-medium text-vor-charcoal mb-1">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-3 rounded-lg border border-vor-sand bg-white text-vor-charcoal font-body focus:outline-none focus:border-vor-gold-dark focus:ring-1 focus:ring-vor-gold-dark"
          placeholder="your@email.com"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-heading font-medium text-vor-charcoal mb-1">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full px-4 py-3 rounded-lg border border-vor-sand bg-white text-vor-charcoal font-body focus:outline-none focus:border-vor-gold-dark focus:ring-1 focus:ring-vor-gold-dark resize-none"
          placeholder="What's on your mind?"
        ></textarea>
      </div>
      <button
        type="submit"
        class="w-full px-6 py-3 text-sm font-heading font-semibold uppercase tracking-wide text-white bg-vor-charcoal rounded-lg hover:bg-vor-charcoal-light transition-colors"
      >
        Send Message
      </button>
    </form>

    <div id="form-success" class="hidden text-center py-8">
      <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-vor-warm border border-vor-sand flex items-center justify-center">
        <svg class="w-6 h-6 text-vor-gold-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h3 class="font-heading font-semibold text-vor-charcoal text-lg mb-2">Message Received</h3>
      <p class="text-vor-charcoal-light">Troy will be in touch.</p>
    </div>

    <div id="form-error" class="hidden text-center py-4 text-red-600 text-sm">
      Something went wrong. Please try again or email directly at
      <a href="mailto:troy@voiceofrepentance.com" class="underline">troy@voiceofrepentance.com</a>.
    </div>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successDiv = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv?.classList.add('hidden');

    const formData = new FormData(form);
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      message: formData.get('message'),
      source: 'blog',
    };

    try {
      const res = await fetch('https://app.voiceofrepentance.com/api/vor/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.classList.add('hidden');
        successDiv?.classList.remove('hidden');
      } else {
        errorDiv?.classList.remove('hidden');
      }
    } catch {
      errorDiv?.classList.remove('hidden');
    }
  });
</script>

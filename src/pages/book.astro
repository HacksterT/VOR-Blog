---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '../utils/readingTime';

const AMAZON_URL = 'https://a.co/d/01tTtUbB';
const OVERVIEW_SLUG = 'journey2health-the-battle-within';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const overviewPost = allPosts.find((p) => p.id === OVERVIEW_SLUG);
const overviewMinutes = overviewPost ? readingTime(overviewPost.body ?? '') : null;
const overviewDate = overviewPost
  ? overviewPost.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const chapters = [
  {
    title: 'The Nature of the Flesh',
    body: 'Genesis 3 and Romans 7 frame the fall as a grasp for autonomy. Every work of the flesh -- jealousy, anger, sexual immorality, selfish ambition -- flows from that same root.',
  },
  {
    title: 'The Fruit of the Spirit',
    body: 'Love, joy, peace, patience, kindness, goodness, faithfulness, gentleness, self-control. Fruit grown on a vine (John 15:5), not virtues manufactured by effort.',
  },
  {
    title: 'The Irony of Autonomy and Surrender',
    body: 'Independence is the exact instinct that drove the fall. The rich young ruler understood the commandments and still walked away. The hardest act of faith is the daily one.',
  },
  {
    title: 'Physical and Mental Health Impacts',
    body: 'Chronic anger activates the HPA axis. Jealousy elevates cortisol. Addiction hijacks the dopaminergic pathway. Love releases oxytocin. Peace regulates blood pressure.',
  },
  {
    title: 'Physiological Pathways',
    body: 'HPA axis, dopaminergic, serotonergic, amygdala, prefrontal cortex. Each one mapped to the behaviors that degrade it and the behaviors that restore it. Appendix reference table included.',
  },
  {
    title: 'The Journey to Health',
    body: 'Repentance as the starting point. Galatians 6:7-8 on sowing and reaping. Daily surrender is not a metaphor for the Christian life -- it is the mechanism of transformation.',
  },
];

const upcomingTitles = [
  'Conquering the Flesh by Embracing the Fruit',
  'The Irony of Autonomy is Surrender',
  'Relational Revival: Unmasking Desires and Building Bridges',
  'Sensual Desires vs. Love and Self-Control',
  'Battling Negative Self-Image and Low Self-Esteem',
  'Improving Relationships through Spiritual Principles',
  'Better Mental and Physical Health?',
  'Realigning Your Compass: Overcoming Misplaced Priorities',
  'Materialism and the Real Meaning Behind Idolatry and Sorcery',
  'Selfish Ambition vs. Faithfulness, Goodness, Self-Control',
  'Chronic Disease as a Consequence',
  'Peace in the Storm by Understanding Why',
  'Managing Stress and Anxiety',
  'Overcoming Addictions with Spiritual and Practical Steps',
  'Dealing with Anger and Resentment through Forgiveness and Peace',
  'Journey to Wholeness: Finding Your Path',
  'Discovering Purpose and Direction',
  'Integrating Spiritual, Mental, and Physical Health for a Fulfilling Life',
];
---

<BaseLayout
  title="The Battle Within: Flesh to Fruit"
  description="Book 1 of the Journey2Health series by Troy E. Sybert, MD, MPH. A physician and minister's integration of Galatians 5 and the science of the body."
  ogImage="/images/book/Cover3.png"
  ogType="book"
>

  <!-- Hero -->
  <section class="bg-vor-cream border-b border-vor-sand">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
        <div class="order-2 md:order-1">
          <span class="inline-block px-3 py-1 text-xs font-heading font-semibold uppercase tracking-widest text-vor-gold-dark bg-vor-warm border border-vor-sand rounded-full mb-6">
            Book 1 &middot; Journey2Health Series
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-vor-charcoal mb-4 leading-tight">
            The Battle Within: Flesh to Fruit
          </h1>
          <p class="text-xl md:text-2xl text-vor-charcoal-light font-body leading-relaxed mb-6">
            Transforming Your Life in a World of Struggle
          </p>
          <p class="text-lg text-vor-charcoal-light font-body leading-relaxed mb-8">
            A physician and minister's integration of Galatians 5 and the science of the body.
            Why the contrast between flesh and Spirit is not only a spiritual category --
            it is a physiological one, with real consequences for your health.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={AMAZON_URL}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center px-8 py-3 text-sm font-heading font-semibold uppercase tracking-wide text-white bg-vor-charcoal rounded-lg hover:bg-vor-charcoal-light transition-colors no-underline"
            >
              Buy on Amazon
            </a>
            <a
              href="#overview"
              class="inline-flex items-center justify-center px-8 py-3 text-sm font-heading font-semibold uppercase tracking-wide text-vor-charcoal border border-vor-sand rounded-lg hover:bg-vor-warm transition-colors no-underline"
            >
              Read the Overview
            </a>
          </div>
          <p class="mt-6 text-sm text-vor-muted font-heading uppercase tracking-wide">
            By Troy E. Sybert, MD, MPH &middot; Published July 2024
          </p>
        </div>
        <div class="order-1 md:order-2 flex justify-center">
          <img
            src="/images/book/Cover3.png"
            alt="The Battle Within: Flesh to Fruit -- book cover"
            class="w-full max-w-sm rounded-lg shadow-xl border border-vor-sand"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- About the Book -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-vor-charcoal mb-8">About the Book</h2>
    <div class="prose prose-lg max-w-none">
      <p>
        In Robert Frost's poem, a traveler stops at a fork in the woods and has to pick
        a path. That divergence is the premise of this book. Every life lived in this
        world comes to the same fork, over and over. The path of the flesh or the path
        of the Spirit. Paul named both in Galatians 5:19-23, and nothing about the stakes
        has changed in two thousand years.
      </p>
      <p>
        What has changed is our capacity to see what those two paths do to the human body.
        Chronic anger, jealousy, sexual indulgence, and addiction are not only spiritual
        deformities. They are also measurable pathologies -- elevated cortisol, dysregulated
        dopamine, weakened immunity, accelerated cardiovascular disease. The fruit of the
        Spirit is the counterweight: oxytocin, serotonin, lower blood pressure, longer and
        more fulfilled life.
      </p>
      <p>
        <strong>The Battle Within</strong> holds those two categories together. It is
        Scripture and clinical medicine in the same frame, written by someone who has
        practiced both for more than two decades. The goal is not another self-help
        template. It is a call to the one path that actually produces the kind of health
        -- spiritual, mental, and physical -- that lasts.
      </p>
    </div>
  </section>

  <!-- What You'll Find Inside -->
  <section class="bg-vor-warm border-y border-vor-sand">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-vor-charcoal mb-4 text-center">
        What You'll Find Inside
      </h2>
      <p class="text-center text-vor-charcoal-light text-lg mb-10 max-w-2xl mx-auto">
        Six movements across roughly a hundred pages. Each one grounded in Scripture and
        carried through the physiology that makes it concrete.
      </p>

      <div class="grid md:grid-cols-2 gap-5">
        {chapters.map((chapter) => (
          <div class="bg-white rounded-lg border border-vor-sand p-5">
            <h3 class="font-heading font-semibold text-vor-charcoal mb-2">{chapter.title}</h3>
            <p class="text-vor-charcoal-light text-sm leading-relaxed">{chapter.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Overview (featured blog post) -->
  {overviewPost && (
    <section id="overview" class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-vor-charcoal mb-4">
        Read the Overview
      </h2>
      <p class="text-vor-charcoal-light text-lg mb-8 max-w-2xl">
        A longer-form walkthrough of the book's argument -- the personal story, the
        scriptural frame, and the clinical bridge -- in one essay.
      </p>

      <a
        href={`/blog/${overviewPost.id}`}
        class="group flex flex-col md:flex-row bg-white rounded-xl border border-vor-sand overflow-hidden hover:shadow-lg transition-shadow duration-300 no-underline"
      >
        <div class="md:w-64 flex-shrink-0 overflow-hidden">
          <img
            src={overviewPost.data.coverImage || '/images/book/Cover3.png'}
            alt={overviewPost.data.title}
            class="w-full h-48 md:h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        </div>
        <div class="p-6 md:p-8 flex flex-col flex-1">
          <div class="flex items-center gap-2">
            <time class="text-xs font-heading text-vor-muted uppercase tracking-wider">
              {overviewDate}
            </time>
            {overviewMinutes && (
              <>
                <span class="text-vor-muted text-xs">&middot;</span>
                <span class="text-xs font-heading text-vor-muted">{overviewMinutes} min read</span>
              </>
            )}
          </div>
          <h3 class="mt-2 text-2xl font-heading font-semibold text-vor-charcoal group-hover:text-vor-gold-dark transition-colors">
            {overviewPost.data.title}
          </h3>
          <p class="mt-3 text-vor-charcoal-light leading-relaxed flex-1">
            {overviewPost.data.description}
          </p>
          <p class="mt-4 text-vor-gold-dark font-heading text-sm font-semibold">
            Read the full overview &rarr;
          </p>
        </div>
      </a>
    </section>
  )}

  <!-- About the Author -->
  <section class="bg-white border-y border-vor-sand">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-vor-charcoal mb-8">About the Author</h2>
      <div class="prose prose-lg max-w-none">
        <p>
          Troy E. Sybert, MD, MPH, is a physician with more than twenty years of experience
          in internal medicine, preventive medicine, public health, and clinical informatics.
          He holds a medical doctorate and a master's in public health and has spent his
          career at the place where faith and medicine intersect.
        </p>
        <p>
          Journey2Health is the culmination of that work. The series is designed to help
          readers navigate modern challenges in health and wellness by embracing the fruit
          of the Spirit instead of the works of the flesh. Troy lives with his family in
          northeast Tennessee and writes from the conviction that the Bible described the
          physiology of the human heart long before the cardiologists did.
        </p>
        <p>
          For more on the voice behind this work, see <a href="/about" class="text-vor-gold-dark hover:text-vor-gold">About Troy and VOR</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Journey2Health Series -->
  <section class="bg-vor-warm border-b border-vor-sand">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-vor-charcoal mb-4 text-center">
        More in the Journey2Health Series
      </h2>
      <p class="text-center text-vor-charcoal-light text-lg mb-10 max-w-2xl mx-auto">
        <strong>The Battle Within: Flesh to Fruit</strong> is the first volume. The series
        will work its way through each fruit of the Spirit, paired with its opposing work
        of the flesh, and the physiological terrain each one occupies.
      </p>

      <ol class="grid md:grid-cols-2 gap-3">
        {upcomingTitles.map((title) => (
          <li class="flex items-start gap-3 bg-white rounded-lg border border-vor-sand px-4 py-3">
            <span class="inline-block mt-0.5 px-2 py-0.5 text-[10px] font-heading font-semibold uppercase tracking-widest text-vor-muted bg-vor-cream border border-vor-sand rounded-full flex-shrink-0">
              Coming
            </span>
            <span class="text-vor-charcoal-light text-sm leading-snug">{title}</span>
          </li>
        ))}
      </ol>

      <p class="text-center text-sm text-vor-muted mt-10">
        Sign up below to be notified as new volumes release.
      </p>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="bg-white border-b border-vor-sand">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-vor-charcoal mb-4">
        Start Where the Series Begins
      </h2>
      <p class="text-lg text-vor-charcoal-light mb-8 max-w-xl mx-auto">
        The path you choose makes all the difference. Book 1 is available now on Amazon.
        Subscribe through the contact page to be notified when future volumes release.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={AMAZON_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center px-8 py-3 text-sm font-heading font-semibold uppercase tracking-wide text-white bg-vor-charcoal rounded-lg hover:bg-vor-charcoal-light transition-colors no-underline"
        >
          Buy on Amazon
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-3 text-sm font-heading font-semibold uppercase tracking-wide text-vor-charcoal border border-vor-sand rounded-lg hover:bg-vor-warm transition-colors no-underline"
        >
          Get Notified of New Releases
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

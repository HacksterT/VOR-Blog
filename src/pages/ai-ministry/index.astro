---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '../../utils/readingTime';

const allPosts = await getCollection('blog');

const theologicalPosts = allPosts
  .filter((p) => p.data.tags.some((t) => t.toLowerCase() === 'theological-series'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const practicalPosts = allPosts
  .filter((p) => p.data.tags.some((t) => t.toLowerCase() === 'practical-series'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const landscapePosts = allPosts
  .filter((p) => p.data.tags.some((t) => t.toLowerCase() === 'landscape-series'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const theologicalFlagship = allPosts.find((p) => p.id === 'is-ai-in-the-church-even-okay');
const practicalFlagship = allPosts.find((p) => p.id === 'what-medicine-and-tech-taught-me-about-ai-in-the-church');
const landscapeFlagship = allPosts.find((p) => p.id === 'five-ai-predictions-physicians-response');

const theologicalFlagshipMinutes = theologicalFlagship ? readingTime(theologicalFlagship.body ?? '') : 0;
const practicalFlagshipMinutes = practicalFlagship ? readingTime(practicalFlagship.body ?? '') : 0;
const landscapeFlagshipMinutes = landscapeFlagship ? readingTime(landscapeFlagship.body ?? '') : 0;
---

<BaseLayout
  title="Examining AI in the Church"
  description="Field notes from a physician building AI for ministry. For pastors and leaders making decisions on behalf of the congregations they serve."
>

  <!-- Hero / Masthead -->
  <section class="relative overflow-hidden border-b border-vor-sand">
    <div class="absolute inset-0">
      <img
        src="/images/site/ai-ministry-hero.jpg"
        alt=""
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-white/90 via-white/75 to-white/40"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <span class="inline-block px-3 py-1 text-xs font-heading font-semibold uppercase tracking-widest text-vor-gold-dark bg-white/90 border border-vor-sand rounded-full mb-6">
        A Series for Ministry Leaders
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-vor-charcoal mb-6 leading-tight md:whitespace-nowrap">
        Examining AI in the Church
      </h1>
      <p class="max-w-2xl text-xl md:text-2xl text-vor-charcoal-light font-body leading-relaxed">
        Field notes from a physician building AI for ministry. For pastors and leaders
        making decisions on behalf of the congregations they serve.
      </p>
    </div>
  </section>

  <!-- Positioning -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <p class="text-vor-charcoal-light text-lg leading-relaxed">
      Pastors and church leaders are getting a lot of first opinions about AI right now,
      mostly from people selling something. I am a believer of more than forty years, a
      physician, and a clinical informaticist, and I am building AI for ministry myself.
      The work here runs along three tracks. The theological track is for leaders sitting
      with the question of whether AI should be used in religion at all. The landscape
      track surveys what is actually happening across the church-AI space -- the surveys,
      the trends, the data worth tracking. The practical track is for leaders who have
      decided to engage and now need to evaluate tools, vendors, and deployment well. Pick
      the one that fits where you are.
    </p>
  </section>

  <!-- Track-tabbed flagship -->
  <section class="bg-white border-y border-vor-sand">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">

      <!-- Tab list -->
      <div role="tablist" aria-label="Series tracks" class="flex flex-col sm:flex-row gap-3 mb-10">
        <button
          type="button"
          role="tab"
          id="tab-theological"
          aria-controls="panel-theological"
          aria-selected="true"
          data-track="theological"
          class="track-tab flex-1 px-6 py-5 text-left rounded-lg border-2 border-vor-sand bg-vor-warm transition-all"
        >
          <div class="flex items-baseline justify-between gap-3">
            <span class="font-heading font-semibold text-vor-charcoal text-lg">Theological Track</span>
            <span class="text-xs font-heading text-vor-muted whitespace-nowrap">
              {theologicalPosts.length} essay{theologicalPosts.length === 1 ? '' : 's'}
            </span>
          </div>
          <p class="mt-2 text-sm text-vor-charcoal-light leading-relaxed">
            Should AI be used in religion at all?
          </p>
        </button>
        <button
          type="button"
          role="tab"
          id="tab-landscape"
          aria-controls="panel-landscape"
          aria-selected="false"
          data-track="landscape"
          class="track-tab flex-1 px-6 py-5 text-left rounded-lg border-2 border-vor-sand bg-vor-warm transition-all"
        >
          <div class="flex items-baseline justify-between gap-3">
            <span class="font-heading font-semibold text-vor-charcoal text-lg">Landscape Track</span>
            <span class="text-xs font-heading text-vor-muted whitespace-nowrap">
              {landscapePosts.length} essay{landscapePosts.length === 1 ? '' : 's'}
            </span>
          </div>
          <p class="mt-2 text-sm text-vor-charcoal-light leading-relaxed">
            What is actually happening in the church-AI space.
          </p>
        </button>
        <button
          type="button"
          role="tab"
          id="tab-practical"
          aria-controls="panel-practical"
          aria-selected="false"
          data-track="practical"
          class="track-tab flex-1 px-6 py-5 text-left rounded-lg border-2 border-vor-sand bg-vor-warm transition-all"
        >
          <div class="flex items-baseline justify-between gap-3">
            <span class="font-heading font-semibold text-vor-charcoal text-lg">Practical Track</span>
            <span class="text-xs font-heading text-vor-muted whitespace-nowrap">
              {practicalPosts.length} essay{practicalPosts.length === 1 ? '' : 's'}
            </span>
          </div>
          <p class="mt-2 text-sm text-vor-charcoal-light leading-relaxed">
            Choosing tools, evaluating vendors, deploying responsibly.
          </p>
        </button>
      </div>

      <!-- Panels (CSS grid stacked, fade-swap on tab change) -->
      <div class="track-panels">

        <!-- Theological panel -->
        <div
          role="tabpanel"
          id="panel-theological"
          aria-labelledby="tab-theological"
          data-track="theological"
          data-active="true"
          class="track-panel"
        >
          {theologicalFlagship && (
            <div class="bg-vor-warm border border-vor-sand rounded-lg p-6 md:p-10 mb-10">
              <span class="inline-block px-3 py-1 text-xs font-heading font-semibold uppercase tracking-widest text-vor-gold-dark bg-white border border-vor-sand rounded-full mb-6">
                Start Here
              </span>
              <div class="grid md:grid-cols-[1fr_auto] gap-8 md:gap-12 items-start">
                <div>
                  <h2 class="text-3xl md:text-4xl font-heading font-bold text-vor-charcoal mb-4 leading-tight">
                    {theologicalFlagship.data.title}
                  </h2>
                  {theologicalFlagship.data.subtitle && (
                    <p class="text-vor-muted font-heading text-sm uppercase tracking-wide mb-4">
                      {theologicalFlagship.data.subtitle}
                    </p>
                  )}
                  <p class="text-vor-charcoal-light text-lg leading-relaxed mb-6">
                    {theologicalFlagship.data.description}
                  </p>
                  <a
                    href={`/blog/${theologicalFlagship.id}`}
                    class="inline-flex items-center px-6 py-3 text-sm font-heading font-semibold uppercase tracking-wide text-white bg-vor-charcoal rounded-lg hover:bg-vor-charcoal-light transition-colors no-underline"
                  >
                    Read the Essay
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
                <div class="hidden md:flex flex-col items-center justify-center text-center px-6 py-4 border-l border-vor-sand min-w-[140px]">
                  <p class="font-heading font-bold text-vor-gold-dark text-2xl">{theologicalFlagshipMinutes}</p>
                  <p class="text-xs font-heading text-vor-muted uppercase tracking-wider mt-1">min read</p>
                  <p class="text-xs font-heading text-vor-muted mt-3">Starting Point</p>
                </div>
              </div>
            </div>
          )}

          {theologicalPosts.length > 0 && (
            <div>
              <h3 class="text-xl md:text-2xl font-heading font-bold text-vor-charcoal mb-2">The Theological Series</h3>
              <p class="text-vor-charcoal-light leading-relaxed mb-6 max-w-2xl">
                Wrestling with the questions that come before any practical decision: the eschatological,
                the theological, the question of authority, the question of formation, and the question of
                discernment.
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {theologicalPosts.map((post) => (
                  <PostCard
                    title={post.data.title}
                    date={post.data.date}
                    description={post.data.description}
                    slug={post.id}
                    tags={post.data.tags}
                    coverImage={post.data.coverImage}
                    readingMinutes={readingTime(post.body ?? '')}
                  />
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Landscape panel -->
        <div
          role="tabpanel"
          id="panel-landscape"
          aria-labelledby="tab-landscape"
          data-track="landscape"
          data-active="false"
          class="track-panel"
        >
          {landscapeFlagship && (
            <div class="bg-vor-warm border border-vor-sand rounded-lg p-6 md:p-10 mb-10">
              <span class="inline-block px-3 py-1 text-xs font-heading font-semibold uppercase tracking-widest text-vor-gold-dark bg-white border border-vor-sand rounded-full mb-6">
                Start Here
              </span>
              <div class="grid md:grid-cols-[1fr_auto] gap-8 md:gap-12 items-start">
                <div>
                  <h2 class="text-3xl md:text-4xl font-heading font-bold text-vor-charcoal mb-4 leading-tight">
                    {landscapeFlagship.data.title}
                  </h2>
                  {landscapeFlagship.data.subtitle && (
                    <p class="text-vor-muted font-heading text-sm uppercase tracking-wide mb-4">
                      {landscapeFlagship.data.subtitle}
                    </p>
                  )}
                  <p class="text-vor-charcoal-light text-lg leading-relaxed mb-6">
                    {landscapeFlagship.data.description}
                  </p>
                  <a
                    href={`/blog/${landscapeFlagship.id}`}
                    class="inline-flex items-center px-6 py-3 text-sm font-heading font-semibold uppercase tracking-wide text-white bg-vor-charcoal rounded-lg hover:bg-vor-charcoal-light transition-colors no-underline"
                  >
                    Read the Essay
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
                <div class="hidden md:flex flex-col items-center justify-center text-center px-6 py-4 border-l border-vor-sand min-w-[140px]">
                  <p class="font-heading font-bold text-vor-gold-dark text-2xl">{landscapeFlagshipMinutes}</p>
                  <p class="text-xs font-heading text-vor-muted uppercase tracking-wider mt-1">min read</p>
                  <p class="text-xs font-heading text-vor-muted mt-3">Starting Point</p>
                </div>
              </div>
            </div>
          )}

          {landscapePosts.length > 0 && (
            <div>
              <h3 class="text-xl md:text-2xl font-heading font-bold text-vor-charcoal mb-2">The Landscape Series</h3>
              <p class="text-vor-charcoal-light leading-relaxed mb-6 max-w-2xl">
                Surveys, statistics, and signals worth tracking. Reading what is actually
                happening across the church-AI space, with the data and the calibration to
                interpret it.
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {landscapePosts.map((post) => (
                  <PostCard
                    title={post.data.title}
                    date={post.data.date}
                    description={post.data.description}
                    slug={post.id}
                    tags={post.data.tags}
                    coverImage={post.data.coverImage}
                    readingMinutes={readingTime(post.body ?? '')}
                  />
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Practical panel -->
        <div
          role="tabpanel"
          id="panel-practical"
          aria-labelledby="tab-practical"
          data-track="practical"
          data-active="false"
          class="track-panel"
        >
          {practicalFlagship && (
            <div class="bg-vor-warm border border-vor-sand rounded-lg p-6 md:p-10 mb-10">
              <span class="inline-block px-3 py-1 text-xs font-heading font-semibold uppercase tracking-widest text-vor-gold-dark bg-white border border-vor-sand rounded-full mb-6">
                Start Here
              </span>
              <div class="grid md:grid-cols-[1fr_auto] gap-8 md:gap-12 items-start">
                <div>
                  <h2 class="text-3xl md:text-4xl font-heading font-bold text-vor-charcoal mb-4 leading-tight">
                    {practicalFlagship.data.title}
                  </h2>
                  {practicalFlagship.data.subtitle && (
                    <p class="text-vor-muted font-heading text-sm uppercase tracking-wide mb-4">
                      {practicalFlagship.data.subtitle}
                    </p>
                  )}
                  <p class="text-vor-charcoal-light text-lg leading-relaxed mb-6">
                    {practicalFlagship.data.description}
                  </p>
                  <a
                    href={`/blog/${practicalFlagship.id}`}
                    class="inline-flex items-center px-6 py-3 text-sm font-heading font-semibold uppercase tracking-wide text-white bg-vor-charcoal rounded-lg hover:bg-vor-charcoal-light transition-colors no-underline"
                  >
                    Read the Essay
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
                <div class="hidden md:flex flex-col items-center justify-center text-center px-6 py-4 border-l border-vor-sand min-w-[140px]">
                  <p class="font-heading font-bold text-vor-gold-dark text-2xl">{practicalFlagshipMinutes}</p>
                  <p class="text-xs font-heading text-vor-muted uppercase tracking-wider mt-1">min read</p>
                  <p class="text-xs font-heading text-vor-muted mt-3">Starting Point</p>
                </div>
              </div>
            </div>
          )}

          {practicalPosts.length > 0 && (
            <div>
              <h3 class="text-xl md:text-2xl font-heading font-bold text-vor-charcoal mb-2">The Practical Series</h3>
              <p class="text-vor-charcoal-light leading-relaxed mb-6 max-w-2xl">
                For church leadership that wants to understand the technology. Frameworks, foundational
                concepts, the Selah build, tool evaluations, and risk and safety -- written for leaders
                who need to evaluate vendor claims and deploy responsibly.
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {practicalPosts.map((post) => (
                  <PostCard
                    title={post.data.title}
                    date={post.data.date}
                    description={post.data.description}
                    slug={post.id}
                    tags={post.data.tags}
                    coverImage={post.data.coverImage}
                    readingMinutes={readingTime(post.body ?? '')}
                  />
                ))}
              </div>
            </div>
          )}
        </div>

      </div>
    </div>
  </section>

  <!-- Speaking & Advising -->
  <section class="bg-vor-warm border-y border-vor-sand">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-vor-charcoal mb-4">
        Speaking, Advising, Consulting
      </h2>
      <p class="text-vor-charcoal-light text-lg leading-relaxed mb-8">
        I speak to ministry leaders, denominational gatherings, and conferences on AI in the church.
        I also work directly with churches and ministry organizations evaluating AI tools or
        considering custom AI initiatives. If your community is wrestling with these questions,
        reach out below.
      </p>

      <form id="ai-ministry-form" class="space-y-5">
        <div class="grid md:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-heading font-medium text-vor-charcoal mb-1">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg border border-vor-sand bg-white text-vor-charcoal font-body focus:outline-none focus:border-vor-gold-dark focus:ring-1 focus:ring-vor-gold-dark"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-heading font-medium text-vor-charcoal mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg border border-vor-sand bg-white text-vor-charcoal font-body focus:outline-none focus:border-vor-gold-dark focus:ring-1 focus:ring-vor-gold-dark"
              placeholder="your@email.com"
            />
          </div>
        </div>
        <div class="grid md:grid-cols-2 gap-5">
          <div>
            <label for="organization" class="block text-sm font-heading font-medium text-vor-charcoal mb-1">
              Organization <span class="text-vor-muted font-normal">(optional)</span>
            </label>
            <input
              type="text"
              id="organization"
              name="organization"
              class="w-full px-4 py-3 rounded-lg border border-vor-sand bg-white text-vor-charcoal font-body focus:outline-none focus:border-vor-gold-dark focus:ring-1 focus:ring-vor-gold-dark"
              placeholder="Church, denomination, ministry, conference"
            />
          </div>
          <div>
            <label for="role" class="block text-sm font-heading font-medium text-vor-charcoal mb-1">
              Role <span class="text-vor-muted font-normal">(optional)</span>
            </label>
            <input
              type="text"
              id="role"
              name="role"
              class="w-full px-4 py-3 rounded-lg border border-vor-sand bg-white text-vor-charcoal font-body focus:outline-none focus:border-vor-gold-dark focus:ring-1 focus:ring-vor-gold-dark"
              placeholder="Pastor, elder, director, organizer"
            />
          </div>
        </div>
        <div>
          <label for="inquiry-type" class="block text-sm font-heading font-medium text-vor-charcoal mb-1">
            Type of inquiry
          </label>
          <select
            id="inquiry-type"
            name="inquiry-type"
            class="w-full px-4 py-3 rounded-lg border border-vor-sand bg-white text-vor-charcoal font-body focus:outline-none focus:border-vor-gold-dark focus:ring-1 focus:ring-vor-gold-dark"
          >
            <option value="speaking">Speaking engagement</option>
            <option value="consulting">Consulting / advisory</option>
            <option value="tool-evaluation">Help evaluating an AI tool</option>
            <option value="custom-ai">Custom AI initiative for our ministry</option>
            <option value="other">Something else</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-heading font-medium text-vor-charcoal mb-1">
            Tell me about your need
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-3 rounded-lg border border-vor-sand bg-white text-vor-charcoal font-body focus:outline-none focus:border-vor-gold-dark focus:ring-1 focus:ring-vor-gold-dark resize-none"
            placeholder="A few sentences about your context, audience, and what you are hoping to address."
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full px-6 py-3 text-sm font-heading font-semibold uppercase tracking-wide text-white bg-vor-charcoal rounded-lg hover:bg-vor-charcoal-light transition-colors"
        >
          Send Inquiry
        </button>
      </form>

      <div id="form-success" class="hidden text-center py-8">
        <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-white border border-vor-sand flex items-center justify-center">
          <svg class="w-6 h-6 text-vor-gold-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="font-heading font-semibold text-vor-charcoal text-lg mb-2">Inquiry Received</h3>
        <p class="text-vor-charcoal-light">Troy will be in touch.</p>
      </div>

      <div id="form-error" class="hidden text-center py-4 text-red-600 text-sm">
        Something went wrong. Please try again or use the
        <a href="/contact" class="underline">contact page</a>.
      </div>
    </div>
  </section>

  <!-- About Troy (brief) -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <h2 class="text-2xl md:text-3xl font-heading font-bold text-vor-charcoal mb-4">About Troy</h2>
    <p class="text-vor-charcoal-light text-lg leading-relaxed mb-4">
      Troy Sybert is a physician trained at the Mayo Clinic with more than two decades in
      internal medicine, preventive medicine, public health, and clinical informatics. His
      current work as a physician helps shape how AI gets adopted into care environments
      where the cost of getting it wrong is measured in human harm. He is the founder of Voice of
      Repentance Ministries and the builder of Selah, a fine-tuned ministry AI in active development.
    </p>
    <a
      href="/about"
      class="inline-flex items-center text-vor-gold-dark hover:text-vor-gold font-heading font-medium text-sm no-underline"
    >
      Read the full About
      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </section>

</BaseLayout>

<style>
  .track-tab[aria-selected="true"] {
    border-color: #A8863E;
    background-color: white;
  }
  .track-tab[aria-selected="false"]:hover {
    border-color: #4A4A4A;
  }
  .track-panels {
    display: grid;
  }
  .track-panel {
    grid-area: 1 / 1;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 250ms ease;
  }
  .track-panel[data-active="true"] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
</style>

<script>
  // Track tab switcher
  const tabs = document.querySelectorAll<HTMLButtonElement>('.track-tab');
  const panels = document.querySelectorAll<HTMLDivElement>('.track-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const track = tab.dataset.track;
      if (!track) return;
      tabs.forEach((t) => {
        t.setAttribute('aria-selected', t.dataset.track === track ? 'true' : 'false');
      });
      panels.forEach((p) => {
        p.dataset.active = (p.dataset.track === track).toString();
      });
    });
  });

  const form = document.getElementById('ai-ministry-form') as HTMLFormElement;
  const successDiv = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv?.classList.add('hidden');

    const formData = new FormData(form);
    const name = formData.get('name') as string;
    const email = formData.get('email') as string;
    const organization = (formData.get('organization') as string) || '';
    const role = (formData.get('role') as string) || '';
    const inquiryType = formData.get('inquiry-type') as string;
    const userMessage = formData.get('message') as string;

    const inquiryLabel: Record<string, string> = {
      'speaking': 'Speaking engagement',
      'consulting': 'Consulting / advisory',
      'tool-evaluation': 'Help evaluating an AI tool',
      'custom-ai': 'Custom AI initiative for our ministry',
      'other': 'Other',
    };

    const contextLines: string[] = [];
    contextLines.push(`Inquiry type: ${inquiryLabel[inquiryType] ?? inquiryType}`);
    if (organization) contextLines.push(`Organization: ${organization}`);
    if (role) contextLines.push(`Role: ${role}`);

    const composedMessage = `${contextLines.join('\n')}\n\n${userMessage}`;

    const data = {
      name,
      email,
      message: composedMessage,
      source: 'ai-ministry',
    };

    try {
      const res = await fetch('https://app.voiceofrepentance.com/api/vor/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.classList.add('hidden');
        successDiv?.classList.remove('hidden');
      } else {
        errorDiv?.classList.remove('hidden');
      }
    } catch {
      errorDiv?.classList.remove('hidden');
    }
  });
</script>

---
const pathname = Astro.url.pathname;

type LeafLink = { href: string; label: string };
type ParentLink = { label: string; children: LeafLink[] };
type NavLink = LeafLink | ParentLink;

const navLinks: NavLink[] = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/music', label: 'Music' },
  {
    label: 'AI in Ministry',
    children: [
      { href: '/ai-ministry', label: 'Learning Tracks' },
      { href: '/selah', label: 'Selah' },
    ],
  },
  { href: '/book', label: 'Book' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}

function isParentActive(children: LeafLink[]): boolean {
  return children.some((c) => isActive(c.href));
}

function hasChildren(link: NavLink): link is ParentLink {
  return 'children' in link;
}
---

<header class="bg-white/80 backdrop-blur-sm border-b border-vor-sand sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="text-xl font-heading font-bold text-vor-charcoal hover:text-vor-gold-dark no-underline">
        Voice of Repentance
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <li class="nav-item relative">
            {hasChildren(link) ? (
              <>
                <button
                  type="button"
                  class:list={[
                    'nav-trigger',
                    isParentActive(link.children) ? 'is-active' : '',
                  ]}
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  <span>{link.label}</span>
                  <svg class="nav-chevron" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 4.5l3 3 3-3" />
                  </svg>
                </button>
                <ul class="nav-panel" role="menu">
                  {link.children.map((child) => (
                    <li role="none">
                      <a
                        href={child.href}
                        role="menuitem"
                        class:list={[
                          'nav-panel-item',
                          isActive(child.href) ? 'is-active' : '',
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={link.href}
                class:list={[
                  'nav-link',
                  isActive(link.href) ? 'is-active' : '',
                ]}
              >
                {link.label}
              </a>
            )}
          </li>
        ))}
      </ul>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-vor-charcoal hover:text-vor-gold-dark bg-transparent border-0 cursor-pointer"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <ul class="flex flex-col gap-1">
        {navLinks.map((link) => (
          <li>
            {hasChildren(link) ? (
              <div class="mobile-submenu" data-open={isParentActive(link.children) ? 'true' : 'false'}>
                <button
                  type="button"
                  class:list={[
                    'mobile-submenu-trigger',
                    isParentActive(link.children) ? 'is-active' : '',
                  ]}
                  aria-expanded={isParentActive(link.children) ? 'true' : 'false'}
                >
                  <span>{link.label}</span>
                  <svg class="mobile-submenu-chevron" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 4.5l3 3 3-3" />
                  </svg>
                </button>
                <ul class="mobile-submenu-panel">
                  {link.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={[
                          'mobile-submenu-item',
                          isActive(child.href) ? 'is-active' : '',
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ) : (
              <a
                href={link.href}
                class:list={[
                  'mobile-link',
                  isActive(link.href) ? 'is-active' : '',
                ]}
              >
                {link.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  /* === Shared base for desktop top-level items === */
  /* Both .nav-link (anchor) and .nav-trigger (button) must render identically. */
  .nav-link,
  .nav-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0;
    margin: 0;
    background: transparent;
    border: 0;
    border-bottom: 2px solid transparent;
    padding-bottom: 4px;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.025em;
    text-transform: uppercase;
    text-decoration: none;
    color: #4A4A4A; /* vor-charcoal-light */
    cursor: pointer;
    transition: color 200ms ease, border-color 200ms ease;
    line-height: 1;
  }
  .nav-link:hover,
  .nav-trigger:hover,
  .nav-trigger:focus-visible {
    color: #A8863E; /* vor-gold-dark */
    outline: none;
  }
  .nav-link.is-active,
  .nav-trigger.is-active {
    color: #A8863E;
    border-bottom-color: #C8A45E; /* vor-gold */
  }

  /* Chevron */
  .nav-chevron {
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
    transition: transform 200ms ease;
    color: currentColor;
  }
  .nav-item:hover .nav-chevron,
  .nav-item:focus-within .nav-chevron,
  .nav-item[data-open="true"] .nav-chevron {
    transform: rotate(180deg);
  }

  /* === Dropdown panel === */
  .nav-panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 12rem;
    background: white;
    border: 1px solid #E8E0D0; /* vor-sand */
    border-radius: 0.5rem;
    box-shadow: 0 10px 25px -5px rgb(0 0 0 / 0.10), 0 8px 10px -6px rgb(0 0 0 / 0.05);
    padding: 0.375rem;
    margin: 0;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(-4px);
    transition: opacity 150ms ease, transform 150ms ease, visibility 0s linear 150ms;
    z-index: 60;
  }

  /* Hover bridge: invisible pad above the panel that fills the 8px gap so
     the mouse path from trigger to panel doesn't drop hover. */
  .nav-item::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 8px;
    pointer-events: none;
  }
  .nav-item:hover::after,
  .nav-item:focus-within::after,
  .nav-item[data-open="true"]::after {
    pointer-events: auto;
  }

  .nav-item:hover .nav-panel,
  .nav-item:focus-within .nav-panel,
  .nav-item[data-open="true"] .nav-panel {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    transition: opacity 150ms ease, transform 150ms ease, visibility 0s linear 0s;
  }

  /* Panel items */
  .nav-panel-item {
    display: block;
    padding: 0.5rem 0.75rem;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: #4A4A4A;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: background-color 150ms ease, color 150ms ease;
    white-space: nowrap;
  }
  .nav-panel-item:hover {
    background-color: #F5F0E8; /* vor-warm */
    color: #A8863E;
  }
  .nav-panel-item.is-active {
    background-color: #F5F0E8;
    color: #A8863E;
  }

  /* === Mobile === */
  .mobile-link,
  .mobile-submenu-trigger,
  .mobile-submenu-item {
    display: block;
    width: 100%;
    padding: 0.5rem 0.75rem;
    margin: 0;
    background: transparent;
    border: 0;
    border-radius: 0.5rem;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.025em;
    text-transform: uppercase;
    text-decoration: none;
    color: #4A4A4A;
    cursor: pointer;
    text-align: left;
    transition: background-color 150ms ease, color 150ms ease;
  }
  .mobile-submenu-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .mobile-link:hover,
  .mobile-submenu-trigger:hover,
  .mobile-submenu-item:hover {
    background-color: #F5F0E8;
    color: #A8863E;
  }
  .mobile-link.is-active,
  .mobile-submenu-trigger.is-active,
  .mobile-submenu-item.is-active {
    background-color: #F5F0E8;
    color: #A8863E;
  }

  .mobile-submenu-chevron {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    transition: transform 200ms ease;
  }
  .mobile-submenu[data-open="true"] .mobile-submenu-chevron {
    transform: rotate(180deg);
  }

  .mobile-submenu-panel {
    list-style: none;
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 0;
    display: none;
  }
  .mobile-submenu[data-open="true"] .mobile-submenu-panel {
    display: block;
  }
  .mobile-submenu-item {
    text-transform: none;
    font-size: 0.8125rem;
  }
</style>

<script>
  // Mobile menu open/close
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    if (icon) {
      icon.setAttribute(
        'd',
        expanded ? 'M4 6h16M4 12h16M4 18h16' : 'M6 18L18 6M6 6l12 12'
      );
    }
  });

  // Mobile accordion
  document.querySelectorAll<HTMLButtonElement>('.mobile-submenu-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const wrapper = trigger.parentElement;
      if (!wrapper) return;
      const isOpen = wrapper.getAttribute('data-open') === 'true';
      wrapper.setAttribute('data-open', String(!isOpen));
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Desktop dropdown click-toggle (works alongside CSS hover for keyboard / touch users)
  const navItems = document.querySelectorAll<HTMLLIElement>('.nav-item');
  navItems.forEach((item) => {
    const trigger = item.querySelector<HTMLButtonElement>('.nav-trigger');
    if (!trigger) return;
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = item.getAttribute('data-open') === 'true';
      navItems.forEach((other) => {
        if (other !== item) {
          other.setAttribute('data-open', 'false');
          other.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
        }
      });
      item.setAttribute('data-open', String(!isOpen));
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    navItems.forEach((item) => {
      if (!item.contains(target)) {
        item.setAttribute('data-open', 'false');
        item.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
      }
    });
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      navItems.forEach((item) => {
        item.setAttribute('data-open', 'false');
        item.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
      });
    }
  });
</script>

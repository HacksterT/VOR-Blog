---
const pathname = Astro.url.pathname;

type LeafLink = { href: string; label: string };
type ParentLink = { label: string; children: LeafLink[] };
type NavLink = LeafLink | ParentLink;

const navLinks: NavLink[] = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/music', label: 'Music' },
  {
    label: 'AI in Ministry',
    children: [
      { href: '/ai-ministry', label: 'Learning Tracks' },
      { href: '/selah', label: 'Selah' },
    ],
  },
  { href: '/book', label: 'Book' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}

function isParentActive(children: LeafLink[]): boolean {
  return children.some((c) => isActive(c.href));
}

function hasChildren(link: NavLink): link is ParentLink {
  return 'children' in link;
}
---

<header class="bg-white/80 backdrop-blur-sm border-b border-vor-sand sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Site name -->
      <a href="/" class="text-xl font-heading font-bold text-vor-charcoal hover:text-vor-gold-dark no-underline">
        Voice of Repentance
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <li class="relative">
            {hasChildren(link) ? (
              <div class="nav-dropdown" data-open="false">
                <button
                  type="button"
                  class:list={[
                    'nav-dropdown-trigger flex items-center gap-1 text-sm font-heading font-medium tracking-wide uppercase transition-colors duration-200',
                    isParentActive(link.children)
                      ? 'text-vor-gold-dark border-b-2 border-vor-gold pb-1'
                      : 'text-vor-charcoal-light hover:text-vor-gold-dark',
                  ]}
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  {link.label}
                  <svg class="nav-chevron w-3 h-3 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <ul class="nav-dropdown-panel absolute right-0 mt-3 min-w-[12rem] bg-white border border-vor-sand rounded-lg shadow-lg py-2">
                  {link.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={[
                          'block px-4 py-2 text-sm font-heading font-medium no-underline transition-colors',
                          isActive(child.href)
                            ? 'text-vor-gold-dark bg-vor-warm'
                            : 'text-vor-charcoal-light hover:text-vor-gold-dark hover:bg-vor-warm',
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ) : (
              <a
                href={link.href}
                class:list={[
                  'text-sm font-heading font-medium tracking-wide uppercase no-underline transition-colors duration-200',
                  isActive(link.href)
                    ? 'text-vor-gold-dark border-b-2 border-vor-gold pb-1'
                    : 'text-vor-charcoal-light hover:text-vor-gold-dark',
                ]}
              >
                {link.label}
              </a>
            )}
          </li>
        ))}
      </ul>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-vor-charcoal hover:text-vor-gold-dark"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <ul class="flex flex-col gap-2">
        {navLinks.map((link) => (
          <li>
            {hasChildren(link) ? (
              <div data-mobile-submenu-open={isParentActive(link.children) ? 'true' : 'false'}>
                <button
                  type="button"
                  class:list={[
                    'mobile-submenu-trigger w-full flex items-center justify-between py-2 px-3 rounded-lg text-sm font-heading font-medium tracking-wide uppercase transition-colors duration-200',
                    isParentActive(link.children)
                      ? 'text-vor-gold-dark bg-vor-warm'
                      : 'text-vor-charcoal-light hover:text-vor-gold-dark hover:bg-vor-warm',
                  ]}
                  aria-expanded={isParentActive(link.children) ? 'true' : 'false'}
                >
                  <span>{link.label}</span>
                  <svg class="mobile-submenu-chevron w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <ul class="mobile-submenu pl-4 mt-1 flex flex-col gap-1">
                  {link.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={[
                          'block py-2 px-3 rounded-lg text-sm font-heading font-medium no-underline transition-colors duration-200',
                          isActive(child.href)
                            ? 'text-vor-gold-dark bg-vor-warm'
                            : 'text-vor-charcoal-light hover:text-vor-gold-dark hover:bg-vor-warm',
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ) : (
              <a
                href={link.href}
                class:list={[
                  'block py-2 px-3 rounded-lg text-sm font-heading font-medium tracking-wide uppercase no-underline transition-colors duration-200',
                  isActive(link.href)
                    ? 'text-vor-gold-dark bg-vor-warm'
                    : 'text-vor-charcoal-light hover:text-vor-gold-dark hover:bg-vor-warm',
                ]}
              >
                {link.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  /* Desktop dropdown: hidden by default, shown on hover, on focus-within, or when explicitly open via click */
  .nav-dropdown-panel {
    display: none;
  }
  .nav-dropdown:hover .nav-dropdown-panel,
  .nav-dropdown:focus-within .nav-dropdown-panel,
  .nav-dropdown[data-open="true"] .nav-dropdown-panel {
    display: block;
  }
  .nav-dropdown:hover .nav-chevron,
  .nav-dropdown[data-open="true"] .nav-chevron {
    transform: rotate(180deg);
  }

  /* Mobile accordion: collapsed by default, expanded when parent has data-mobile-submenu-open=true */
  .mobile-submenu {
    display: none;
  }
  [data-mobile-submenu-open="true"] .mobile-submenu {
    display: flex;
  }
  [data-mobile-submenu-open="true"] .mobile-submenu-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');

    if (icon) {
      icon.setAttribute(
        'd',
        expanded ? 'M4 6h16M4 12h16M4 18h16' : 'M6 18L18 6M6 6l12 12'
      );
    }
  });

  // Mobile submenu accordion
  const mobileSubmenuTriggers = document.querySelectorAll<HTMLButtonElement>('.mobile-submenu-trigger');
  mobileSubmenuTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const wrapper = trigger.parentElement;
      if (!wrapper) return;
      const isOpen = wrapper.getAttribute('data-mobile-submenu-open') === 'true';
      wrapper.setAttribute('data-mobile-submenu-open', String(!isOpen));
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Desktop dropdown click-toggle (keeps it usable for keyboard / touch users alongside hover)
  const dropdowns = document.querySelectorAll<HTMLDivElement>('.nav-dropdown');
  dropdowns.forEach((dropdown) => {
    const trigger = dropdown.querySelector<HTMLButtonElement>('.nav-dropdown-trigger');
    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown.getAttribute('data-open') === 'true';
      dropdowns.forEach((d) => {
        d.setAttribute('data-open', 'false');
        d.querySelector('.nav-dropdown-trigger')?.setAttribute('aria-expanded', 'false');
      });
      dropdown.setAttribute('data-open', String(!isOpen));
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Close desktop dropdowns on outside click or Escape
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    dropdowns.forEach((dropdown) => {
      if (!dropdown.contains(target)) {
        dropdown.setAttribute('data-open', 'false');
        dropdown.querySelector('.nav-dropdown-trigger')?.setAttribute('aria-expanded', 'false');
      }
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      dropdowns.forEach((dropdown) => {
        dropdown.setAttribute('data-open', 'false');
        dropdown.querySelector('.nav-dropdown-trigger')?.setAttribute('aria-expanded', 'false');
      });
    }
  });
</script>

---
const year = new Date().getFullYear();
---

<footer class="border-t border-vor-sand bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-vor-muted">
        &copy; {year} Voice of Repentance. All rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <!-- YouTube -->
        <a
          href="https://www.youtube.com/@VoiceofRepentance"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Voice of Repentance on YouTube"
          class="text-vor-muted hover:text-vor-gold-dark transition-colors"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
            <polygon fill="white" points="9.545,15.568 15.818,12 9.545,8.432"/>
          </svg>
        </a>
        <!-- Facebook -->
        <a
          href="https://www.facebook.com/voiceofrepentance/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Voice of Repentance on Facebook"
          class="text-vor-muted hover:text-vor-gold-dark transition-colors"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

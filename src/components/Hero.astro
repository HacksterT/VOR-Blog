---
interface Props {
  title?: string;
  tagline?: string;
  image?: string;
}

const {
  title = 'Voice of Repentance',
  tagline = "Repentance isn't a moment. It's the life you're called to live.",
  image = '/images/site/wheat-field-main-hero.png',
} = Astro.props;
---

<section class="relative border-b border-vor-sand overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src={image}
      alt=""
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-white/75 via-white/55 to-white/20"></div>
  </div>

  <!-- Content -->
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36">
    <div class="md:flex md:items-center md:gap-10">
      <div class="max-w-2xl flex-1">
        <h1 class="text-4xl sm:text-5xl md:text-6xl text-vor-charcoal leading-tight">
          {title}
        </h1>
        <p class="mt-6 text-lg md:text-xl text-vor-charcoal-light leading-relaxed">
          {tagline}
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/blog"
            class="inline-flex items-center px-6 py-3 bg-vor-charcoal text-white font-heading font-medium text-sm rounded-lg hover:bg-vor-charcoal-light no-underline transition-colors"
          >
            Read the Blog
          </a>
          <a
            href="/about"
            class="inline-flex items-center px-6 py-3 border border-vor-sand text-vor-charcoal font-heading font-medium text-sm rounded-lg hover:bg-white/60 no-underline transition-colors backdrop-blur-sm"
          >
            About Troy
          </a>
        </div>
        <!-- Mobile-only survey link -->
        <a
          href="/am-i-saved"
          class="mt-5 md:hidden inline-flex items-center text-vor-gold-dark hover:text-vor-gold font-heading font-semibold text-sm no-underline"
        >
          Am I Saved? Take the Survey
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- Desktop survey card (right-aligned) -->
      <aside class="hidden md:block flex-shrink-0 w-72 bg-white/85 backdrop-blur-sm border border-vor-sand rounded-xl p-6 shadow-sm">
        <span class="inline-block px-2.5 py-1 text-[10px] font-heading font-semibold uppercase tracking-widest text-vor-gold-dark bg-vor-warm border border-vor-sand rounded-full mb-4">
          5 Minutes &middot; Free
        </span>
        <h2 class="text-2xl font-heading font-bold text-vor-charcoal mb-2 leading-snug">
          Am I Saved?
        </h2>
        <p class="text-sm text-vor-charcoal-light leading-relaxed mb-5">
          Eight honest questions and a clear-eyed assessment. Get your assessment by email.
        </p>
        <a
          href="/am-i-saved"
          class="inline-flex items-center justify-center w-full px-4 py-2.5 text-xs font-heading font-semibold uppercase tracking-wide text-white bg-vor-charcoal rounded-lg hover:bg-vor-charcoal-light no-underline transition-colors"
        >
          Take the Survey
          <svg class="w-3.5 h-3.5 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </aside>
    </div>
  </div>
</section>
